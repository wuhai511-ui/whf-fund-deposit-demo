datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Merchant {
  id               String    @id @default(cuid())
  name             String
  industry         String
  status           String    @default("pending")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  ledgerCount      Int       @default(0)
  balance          Float     @default(0)
  address          String?
  rating           Float?
  service_count    Int?
  description      String?
  tags             String    // Changed from String[] to String to store as JSON string
  logo             String?
}

model Consumer {
  id          String   @id @default(cuid())
  open_id     String?  @unique
  phone       String?  @unique
  name        String
  status      String   @default("active")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  ledgerCount Int      @default(0)
}

model Ledger {
  id               String    @id @default(cuid())
  merchant_id      String
  merchant_name    String
  merchant_logo    String?
  consumer_id      String
  consumer_name    String? // Denormalized for easier display
  balance          Float     @default(0)
  total_deposited  Float     @default(0)
  total_spent      Float     @default(0)
  status           String    @default("active")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([merchant_id])
  @@index([consumer_id])
}

model Transaction {
  id            String   @id @default(cuid())
  ledger_id     String
  merchant_id   String
  merchant_name String
  consumer_id   String
  type          String // deposit, withdraw, refund
  amount        Float
  balance_before Float
  balance_after Float
  status        String // pending, completed, failed
  description   String?
  created_at    DateTime @default(now())

  @@index([ledger_id])
  @@index([merchant_id])
  @@index([consumer_id])
}

model Settlement {
  id           String   @id @default(cuid())
  merchant_id  String
  merchant_name String
  period       String // e.g., "2026-W13"
  total_amount Float
  fee          Float    @default(0)
  net_amount   Float
  status       String   @default("pending") // pending, completed, failed
  created_at   DateTime @default(now())

  @@index([merchant_id])
}
